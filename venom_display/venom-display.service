[Unit]
Description=Venom Display Daemon - Screen Management Service
Documentation=https://github.com/vaxp/venom-display
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=/usr/bin/venom_display
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
