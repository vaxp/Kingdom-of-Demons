# ═══════════════════════════════════════════════════════════════════════════
# AVAXP SAM - Systemd User Service Presets
# ═══════════════════════════════════════════════════════════════════════════
# هذا الملف يُفعّل خدمات Venom تلقائياً عند أول تسجيل دخول
# ═══════════════════════════════════════════════════════════════════════════

# Core Services
enable venom-input.service
enable venom-osd.service
enable venom-clipboard.service
enable venom-auth.service

# Power & System
enable venom-power.service

# Notifications
enable venom-notify.service

# Audio & Display
enable venom-audio.service
enable venom-display.service

# Network
enable venom-network.service

# Shortcuts & Screenshots
enable venom-shortcuts.service
enable venom-shot.service

# System Tray
enable venom-sni.service
